{
  "info": {
    "name": "EasierNotes — Pruebas de Sistema (E2E)",
    "description": "Pruebas de SISTEMA sobre EasierNotes desplegado (backend .NET + MySQL). Ejercen RECORRIDOS completos de usuario de extremo a extremo por la interfaz HTTP del sistema, verificando el estado tras cada paso. Nivel: sistema (caja negra sobre el sistema integrado en ejecución). Requiere el sistema corriendo en {{baseUrl}} con su base de datos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Recorrido A — Ciclo de vida completo de una nota",
      "item": [
        {
          "name": "A1. Crear nota",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "create"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('A1: la nota se crea (200)', () => pm.response.to.have.status(200));",
                  "const n = pm.response.json();",
                  "pm.collectionVariables.set('notaA', n.id);",
                  "pm.environment.set('notaA', n.id);",
                  "pm.test('A1: tiene identificador válido', function () {",
                  "    pm.expect(pm.response.json().id).to.be.above(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "A2. Verificar que existe en el sistema",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/{{notaA}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "{{notaA}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('A2: la nota recién creada se puede consultar', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "A3. Editar el contenido",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/update",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "update"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{notaA}}\",\n  \"name\": \"Plan de proyecto\",\n  \"html\": \"<p>Fase 1: análisis.</p>\",\n  \"categoryId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let b = JSON.parse(pm.request.body.raw);",
                  "b.id = Number(pm.collectionVariables.get('notaA'));",
                  "pm.request.body.raw = JSON.stringify(b);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('A3: la edición se guarda (204)', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        },
        {
          "name": "A4. Verificar que el cambio persiste",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/{{notaA}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "{{notaA}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('A4: el contenido editado persiste en el sistema', function () {",
                  "    const n = pm.response.json();",
                  "    pm.expect(n.name).to.eql('Plan de proyecto');",
                  "    pm.expect(n.html).to.include('Fase 1');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "A5. Asociar a una categoría",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/addToCategory/{{notaA}}/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "addToCategory",
                "{{notaA}}",
                "1"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('A5: la asociación a categoría se realiza (204)', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        },
        {
          "name": "A6. Eliminar la nota",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/delete/{{notaA}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "delete",
                "{{notaA}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('A6: la nota se elimina (204)', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        },
        {
          "name": "A7. Verificar que ya no existe",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/{{notaA}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "{{notaA}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('A7: tras eliminar, la nota ya no existe (404)', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Recorrido B — Numeración de notas por defecto",
      "item": [
        {
          "name": "B0. Preparar: contar notas 'Nueva Nota' actuales",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const arr = pm.response.json();",
                  "const qty = arr.filter(n => n.name && n.name.startsWith('Nueva Nota')).length;",
                  "pm.collectionVariables.set('baseQty', qty);",
                  "pm.test('B0: sistema disponible para el recorrido', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "B1. Crear primera nota por defecto",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "create"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const n = pm.response.json();",
                  "pm.collectionVariables.set('notaB1', n.id);",
                  "pm.environment.set('notaB1', n.id);",
                  "pm.test('B1: la nota recibe un nombre por defecto', function () {",
                  "    pm.expect(pm.response.json().name).to.include('Nueva Nota');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "B2. Crear segunda nota por defecto",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "create"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const n = pm.response.json();",
                  "pm.collectionVariables.set('notaB2', n.id);",
                  "pm.environment.set('notaB2', n.id);",
                  "pm.test('B2: la segunda nota lleva un sufijo numérico', function () {",
                  "    pm.expect(pm.response.json().name).to.match(/Nueva Nota \\(\\d+\\)/);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "B3. Limpieza B1",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/delete/{{notaB1}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "delete",
                "{{notaB1}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('B3: limpieza ok', () => pm.expect([204,404]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        },
        {
          "name": "B4. Limpieza B2",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/delete/{{notaB2}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "delete",
                "{{notaB2}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('B4: limpieza ok', () => pm.expect([204,404]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Recorrido C — Robustez ante recursos inexistentes",
      "item": [
        {
          "name": "C1. Consultar nota inexistente",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/999999",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "999999"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('C1: consultar inexistente -> 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        },
        {
          "name": "C2. Editar nota inexistente",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/update",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "update"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 999999,\n  \"name\": \"x\",\n  \"html\": \"<p>y</p>\",\n  \"categoryId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('C2: editar inexistente -> 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        },
        {
          "name": "C3. Eliminar nota inexistente",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/delete/999999",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "delete",
                "999999"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('C3: eliminar inexistente -> 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        },
        {
          "name": "C4. El sistema sigue operativo tras los errores",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('C4: el sistema sigue respondiendo tras los 404', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
